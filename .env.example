# Server
PORT=3000

# PostgreSQL — local or DigitalOcean Managed DB
DATABASE_URL=postgresql://openbrain:yourpassword@localhost:5432/openbrain

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Discord application public key (from Discord Developer Portal)
DISCORD_PUBLIC_KEY=your_discord_public_key_hex

# Shared secret for MCP clients — generate with: openssl rand -hex 32
MCP_ACCESS_KEY=your_secure_random_string
